# Flight Tracker - Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control!

# Site
SITE_NAME=Track Me

# Database
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# Admin Authentication (generate a secure random string, 32+ chars)
ADMIN_SECRET_CODE=change_this_to_a_secure_random_string

# Session (seconds)
SESSION_TIMEOUT=3600

# Rate Limiting
API_RATE_LIMIT=100
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
